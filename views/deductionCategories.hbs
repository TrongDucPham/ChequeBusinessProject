<h1>Deduction Categories</h1>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Category Name</th>
        </tr>
    </thead>

    <tbody>
        {{#each categories}}
        <tr>
            <td>{{categoryID}}</td>
            <td>{{categoryName}}</td>
        </tr>
        {{/each}}
    </tbody>
</table>

<hr>

<h2>Add Deduction Category</h2>
<form method="POST" action="/DeductionCategories/create" class="cuForm">
    <label>Category Name:</label>
    <input type="text" name="categoryName" required>

    <input type="submit" value="Add Category">
</form>
