<h1>Time Entries</h1>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Employee</th>
            <th>Date</th>
            <th>Hours Worked</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        {{#each entries}}
        <tr data-id="{{timeEntryID}}">
            <td>{{timeEntryID}}</td>
            <td>{{firstName}} {{lastName}}</td>
            <td>{{workDate}}</td>
            <td>{{hoursWorked}}</td>

            <td>
                <div class="normal-actions">
                    <button class="edit-btn">Edit</button>
                </div>

                <div class="edit-actions" style="display:none;">
                    <form method="POST" action="/TimeEntries/delete" style="display:inline;">
                        <input type="hidden" name="timeEntryID" value="{{timeEntryID}}">
                        <button type="submit">Delete</button>
                    </form>

                    <form method="POST" action="/TimeEntries/update" style="display:inline;">
                        <input type="hidden" name="timeEntryID" value="{{timeEntryID}}">

                        <select name="employeeID">
                            {{#each ../employees}}
                                <option value="{{this.employeeID}}"
                                    {{#if (eq this.employeeID ../employeeID)}}selected{{/if}}>
                                    {{this.firstName}} {{this.lastName}}
                                </option>
                            {{/each}}
                        </select>

                        <input type="date" name="workDate" value="{{workDate}}">
                        <input type="number" step="0.01" name="hoursWorked" value="{{hoursWorked}}">

                        <button type="submit">Save</button>
                    </form>

                    <button class="cancel-btn">Cancel</button>
                </div>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

<hr>

<h2>Add Time Entry</h2>
<form method="POST" action="/TimeEntries/create" class="cuForm">
    <label>Employee:</label>
    <select name="employeeID" required>
        <option value="" disabled selected>Select Employee</option>
        {{#each employees}}
        <option value="{{employeeID}}">{{firstName}} {{lastName}}</option>
        {{/each}}
    </select>

    <label>Date:</label>
    <input type="date" name="workDate" required>

    <label>Hours Worked:</label>
    <input type="number" step="0.01" name="hoursWorked" required>

    <input type="submit" value="Add Entry">
</form>

<script>
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.edit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const row = btn.closest('tr');
            row.querySelector('.normal-actions').style.display = 'none';
            row.querySelector('.edit-actions').style.display = 'inline-block';
        });
    });

    document.querySelectorAll('.cancel-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const row = btn.closest('tr');
            row.querySelector('.normal-actions').style.display = 'inline-block';
            row.querySelector('.edit-actions').style.display = 'none';
        });
    });
});
</script>
